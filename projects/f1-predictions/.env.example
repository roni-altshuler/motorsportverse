# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — never commit your real key.
# Full reference: docs/ENV_VARS.md. Everything here is OPTIONAL for local dev.

# --- Pipeline toggles (sensible defaults if unset) ---
# F1_SEASON_YEAR=2026            # which season to predict/publish
# F1_USE_LIVE_STANDINGS=1        # pull official standings on each export
# F1_USE_LIVE_ROUND_RESULTS=1    # refresh actual results when a round completes
# F1_REGISTRY_ENABLED=1          # set 0 to make the model registry a no-op (tests)

# --- Website (Next.js) build-time, NEXT_PUBLIC_* only ---
# NEXT_PUBLIC_SITE_URL=http://localhost:3000   # absolute URLs for OG/sitemap in dev
# NEXT_PUBLIC_BASE_PATH=                        # GitHub Pages subpath (auto-set in CI)


# OddsAPI key — free tier 500 requests/month at https://the-odds-api.com/
# Used by odds_ingest.py and export_value_data.py.
# NOTE: as of 2026-05, The Odds API does NOT cover F1 / motorsport. The key
# still works (no quota burned on the 404) but no live F1 outrights data is
# available there. Use the CSV path or the Betfair path below.
ODDS_API_KEY=

# Betfair Exchange — free with a KYC'd Betfair account (UK/IE/AU/GR/ES/IT/DE)
# Get an app key at https://developer.betfair.com/
# Used by odds_ingest_betfair.py.
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_APP_KEY=
# Optional cert-based login (more reliable than interactive in CI):
# BETFAIR_CERT_PATH=/path/to/client-2048.crt
# BETFAIR_CERT_KEY_PATH=/path/to/client-2048.key

# Optional toggles documented in the README; uncomment if you need them.
# F1_USE_LIVE_STANDINGS=1
# F1_USE_LIVE_ROUND_RESULTS=1
# ENABLE_GAME_THEORY_ENHANCEMENTS=1
