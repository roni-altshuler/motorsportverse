# ========================
# Python
# ========================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ========================
# Jupyter / IPython
# ========================
.ipynb_checkpoints/
*.ipynb_checkpoints

# ========================
# FastF1 data cache
# ========================
f1_cache/
weather_cache/

# ========================
# Generated visualisations (reproducible — regenerate by running the scripts)
# ========================
visualizations/
# Keep website copies (committed by CI)
!website/public/visualizations/

# ========================
# Generated HTML reports (reproducible)
# ========================
reports/

# ========================
# Season results tracking (auto-generated)
# ========================
season_results_2026.json
season_tracker_2026.json
# Keep the website copy committed by CI
!website/public/data/season_tracker.json

# ========================
# Backup files
# ========================
*_v1.py

# ========================
# Model registry binaries (metadata.json IS committed)
# ========================
models/registry/**/*.joblib
models/registry/**/*.pt
# Keep staging-dir leftovers out (tempfile.TemporaryDirectory with prefix=".")
models/registry/.*_*/

# ========================
# Conformal residual cache (per-round held-out residuals)
# Files are tiny but regenerated by every train_ensemble call.
# ========================
data/conformal_residuals/

# ========================
# OS files
# ========================
.DS_Store
Thumbs.db
desktop.ini

# ========================
# IDE / Editor
# ========================
.vscode/
.idea/
*.swp
*.swo
*~

# ========================
# Virtual environments
# ========================
.env
.venv
env/
venv/

# ========================
# Betting / odds (gitignored — contains API responses, snapshots, DBs)
# ========================
odds_cache/
# manual CSV drops for odds_ingest_unified.py
odds_inbox/
# anchored: only top-level DuckDB dir; doesn't capture website/public/data/
/data/
# Headshot manifest written by scripts/fetch_driver_headshots.py — it IS
# committed so the website builds without re-fetching from openf1.org.
!/data/driver_headshots.json

# ========================
# Misc
# ========================
*.log
node_modules/
.attic/

# OG images are regenerated by website/scripts/generate-og.tsx via 'npm run prebuild'
website/public/og/

# Diagnostic rebuild scratch (regenerable via diagnostics/rebuild.py)
/diagnostics/rebuild_2026/
